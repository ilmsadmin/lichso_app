<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!--
        Android 15 (API 35) enforces edge-to-edge by default.
        statusBarColor and navigationBarColor are ignored.
        The app must handle insets via WindowInsets in Compose.
    -->
    <style name="Theme.LichSo" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:windowBackground">#FFFFFBF5</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <style name="Theme.LichSo.Splash" parent="android:Theme.Material.NoActionBar">
        <item name="android:windowBackground">@color/splash_background</item>
        <item name="android:windowLightStatusBar">false</item>
        <!-- Hide default app icon — our Compose SplashScreen handles it -->
        <item name="android:windowSplashScreenBackground">@color/splash_background</item>
        <item name="android:windowSplashScreenAnimatedIcon">@android:color/transparent</item>
    </style>
</resources>
