<?xml version="1.0" encoding="utf-8"?>
<!-- Widget 2×2 — Lịch ngày (DARK theme) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="8dp"
    android:background="@drawable/widget_cal_bg_dark">

    <!-- Day of week -->
    <TextView
        android:id="@+id/tv_day_of_week"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Thứ Ba"
        android:textSize="11sp"
        android:textColor="#B3FFFFFF"
        android:textStyle="bold" />

    <!-- Large solar day -->
    <TextView
        android:id="@+id/tv_solar_day"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="07"
        android:textSize="42sp"
        android:textColor="#FFFFFF"
        android:textStyle="bold"
        android:includeFontPadding="false" />

    <!-- Month year -->
    <TextView
        android:id="@+id/tv_solar_month_year"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="tháng 4 · 2026"
        android:textSize="10sp"
        android:textColor="#B3FFFFFF" />

    <!-- Divider -->
    <TextView
        android:layout_width="50dp"
        android:layout_height="1dp"
        android:background="#33FFFFFF"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="4dp" />

    <!-- Lunar -->
    <TextView
        android:id="@+id/tv_lunar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="20 · tháng 2 Âm"
        android:textSize="10sp"
        android:textColor="#FFD700"
        android:textStyle="bold" />

    <!-- Can Chi -->
    <TextView
        android:id="@+id/tv_can_chi"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Tân Hợi · Bính Ngọ"
        android:textSize="9sp"
        android:textColor="#B3FFFFFF"
        android:layout_marginTop="1dp" />

    <!-- Day rating -->
    <TextView
        android:id="@+id/tv_day_rating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✦ Ngày Hoàng Đạo"
        android:textSize="9sp"
        android:textColor="#81C784"
        android:layout_marginTop="2dp" />

</LinearLayout>
