<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- Header section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="8dp"
        android:background="#B71C1C"
        android:gravity="center_vertical">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔮 Tử Vi Hôm Nay"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_ai_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="07/04/2026"
            android:textColor="#FFFFFF"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- User info section -->
    <LinearLayout
        android:id="@+id/widget_ai_user_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        android:background="#FFFFFF">

        <TextView
            android:id="@+id/widget_ai_user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Chưa có thông tin người dùng"
            android:textColor="#333333"
            android:textSize="13sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_ai_user_zodiac"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tuổi: Chưa xác định"
            android:textColor="#666666"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/widget_ai_user_canchi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Can Chi: Chưa xác định"
            android:textColor="#D4A017"
            android:textSize="11sp"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- AI prediction section -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginTop="8dp"
        android:padding="10dp"
        android:background="#FFFFFF">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Vận mệnh hôm nay:"
            android:textColor="#666666"
            android:textSize="11sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/widget_ai_prediction"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:layout_marginTop="4dp"
            android:text="Chạm để xem lời khuyên từ AI Tử Vi..."
            android:textColor="#333333"
            android:textSize="12sp"
            android:lineSpacingExtra="2dp"
            android:maxLines="6"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Footer - click to open AI chat -->
    <TextView
        android:id="@+id/widget_ai_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:text="💬 Chạm để hỏi AI Tử Vi"
        android:textColor="#B71C1C"
        android:textSize="11sp"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="6dp"
        android:background="#FFEBEE" />

</LinearLayout>
