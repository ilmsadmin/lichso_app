        android:paddingBottom="2dp">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="T2" android:textSize="10sp" android:textStyle="bold" android:textColor="#857371" />
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:gravity="center" android:text="T3" android:textSize="10sp" android:textStyle="bold" android:textColor="#857371" />
