<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="8dp">

    <!-- Header section -->
    <LinearLayout
        android:id="@+id/header_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="8dp"
        android:background="#B71C1C">

        <TextView
            android:id="@+id/widget_month_year"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Tháng 4, 2026"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_gravity="center_horizontal" />

        <TextView
            android:id="@+id/widget_can_chi"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Năm Bính Ngọ"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_gravity="center_horizontal"
            android:layout_marginTop="2dp" />
    </LinearLayout>

    <!-- Today's date section -->
    <LinearLayout
        android:id="@+id/today_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_below="@id/header_section"
        android:layout_marginTop="8dp"
        android:padding="12dp"
        android:background="#FFFFFF">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/widget_solar_day"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="7"
                android:textColor="#B71C1C"
                android:textSize="48sp"
                android:textStyle="bold"
                android:layout_marginEnd="12dp" />

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:id="@+id/widget_day_of_week"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Thứ Hai"
                    android:textColor="#333333"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/widget_lunar_date"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ngày 10 tháng 3"
                    android:textColor="#666666"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />

                <TextView
                    android:id="@+id/widget_day_can_chi"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Giáp Tý"
                    android:textColor="#D4A017"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Day rating -->
        <TextView
            android:id="@+id/widget_day_rating"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ngày tốt"
            android:textColor="#2E7D32"
            android:textSize="12sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            android:padding="4dp"
            android:background="#E8F5E9" />
    </LinearLayout>

    <!-- Moon phase and additional info -->
    <LinearLayout
        android:id="@+id/info_section"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_below="@id/today_section"
        android:layout_marginTop="8dp"
        android:padding="8dp"
        android:background="#FFFFFF">

        <TextView
            android:id="@+id/widget_moon_phase"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🌒 Trăng non"
            android:textColor="#666666"
            android:textSize="11sp" />

        <TextView
            android:id="@+id/widget_tiet_khi"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Thanh Minh"
            android:textColor="#666666"
            android:textSize="11sp"
            android:gravity="end" />
    </LinearLayout>

    <!-- Footer - click to open app -->
    <TextView
        android:id="@+id/widget_footer"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/info_section"
        android:layout_marginTop="8dp"
        android:text="Chạm để xem chi tiết"
        android:textColor="#999999"
        android:textSize="10sp"
        android:gravity="center"
        android:padding="4dp" />

</RelativeLayout>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg">

    <!-- Header row: large solar day + day-of-week / month-year -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/tv_solar_day"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="07"
            android:textSize="52sp"
            android:textColor="#B71C1C"
            android:textStyle="bold"
            android:fontFamily="sans-serif-condensed"
            android:includeFontPadding="false"
            android:lineSpacingExtra="0dp" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="10dp">

            <TextView
                android:id="@+id/tv_day_of_week"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Thứ Ba"
                android:textSize="13sp"
                android:textColor="#1C1B1F"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_solar_month_year"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="tháng 4 · 2026"
                android:textSize="11sp"
                android:textColor="#857371"
                android:layout_marginTop="1dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#22D8C2BF"
        android:layout_marginTop="4dp"
        android:layout_marginBottom="6dp" />

    <!-- Lunar date + year can chi -->
    <TextView
        android:id="@+id/tv_lunar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Mùng 1 tháng 3 Âm lịch"
        android:textSize="12sp"
        android:textColor="#D4A017"
        android:textStyle="bold" />

    <!-- Day can chi -->
    <TextView
        android:id="@+id/tv_can_chi"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Ngày Nhâm Tuất · Năm Ất Tỵ"
        android:textSize="11sp"
        android:textColor="#534340"
        android:layout_marginTop="2dp" />

    <!-- Day rating -->
    <TextView
        android:id="@+id/tv_day_rating"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="✦ Ngày Hoàng Đạo"
        android:textSize="11sp"
        android:textColor="#2E7D32"
        android:layout_marginTop="4dp" />

</LinearLayout>
