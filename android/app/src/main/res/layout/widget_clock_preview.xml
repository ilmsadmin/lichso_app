<?xml version="1.0" encoding="utf-8"?>
<!-- Preview layout cho Clock Widget (dùng trong widget picker) -->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_clock_bg"
    android:padding="16dp">

    <!-- ===== LEFT: Time & Date ===== -->
    <LinearLayout
        android:id="@+id/section_left"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_alignParentStart="true"
        android:layout_toStartOf="@+id/divider"
        android:orientation="vertical"
        android:gravity="center_vertical">

        <!-- Static time (thay TextClock) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="14:30"
            android:textSize="46sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:includeFontPadding="false" />

        <!-- Solar date -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thứ Ba, 07/04/2026"
            android:textSize="13sp"
            android:textColor="#E6FFFFFF"
            android:layout_marginTop="2dp" />

        <!-- Lunar date -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="☽ 20/02 Âm · Bính Dần"
            android:textSize="11sp"
            android:textColor="#E6FFD700"
            android:layout_marginTop="1dp" />

    </LinearLayout>

    <!-- ===== VERTICAL DIVIDER ===== -->
    <FrameLayout
        android:id="@+id/divider"
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:background="#33FFFFFF" />

    <!-- ===== RIGHT: Weather ===== -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        android:layout_toEndOf="@+id/divider"
        android:layout_alignParentEnd="true"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="⛅"
            android:textSize="36sp"
            android:includeFontPadding="false" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="28°"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:includeFontPadding="false" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Có mây"
            android:textSize="11sp"
            android:textColor="#B3FFFFFF" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="💧 75%  💨 12 km/h"
            android:textSize="9sp"
            android:textColor="#80FFFFFF"
            android:layout_marginTop="1dp" />

    </LinearLayout>

    <!-- ===== BOTTOM BADGE ===== -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_alignParentStart="true"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_badge_bg"
        android:paddingStart="8dp"
        android:paddingEnd="10dp"
        android:paddingTop="3dp"
        android:paddingBottom="3dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦"
            android:textSize="11sp"
            android:textColor="#81C784" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Ngày Hoàng Đạo"
            android:textSize="10sp"
            android:textColor="#CCFFFFFF"
            android:layout_marginStart="4dp" />

    </LinearLayout>

</RelativeLayout>
