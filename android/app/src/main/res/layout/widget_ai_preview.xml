<?xml version="1.0" encoding="utf-8"?>
<!-- Preview layout cho AI Chat Widget (dùng trong widget picker) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_ai_card_bg">

    <!-- ===== HEADER (red gradient) ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_ai_header_bg"
        android:padding="10dp">

        <FrameLayout
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/widget_ai_avatar_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="✦"
                android:textSize="14sp"
                android:textColor="#FFD54F" />

        </FrameLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lịch Số AI"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Đang hoạt động"
                android:textSize="9sp"
                android:textColor="#99FFFFFF" />

        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="7/4"
            android:textSize="10sp"
            android:textColor="#CCFFFFFF" />

    </LinearLayout>

    <!-- ===== CHAT AREA ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="8dp"
        android:gravity="top">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_ai_bubble_bg"
            android:padding="8dp"
            android:text="✦ Hôm nay Ngày Hoàng Đạo, hướng tài lộc Đông Nam"
            android:textSize="11sp"
            android:textColor="#1C1B1F"
            android:maxLines="2"
            android:ellipsize="end" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:background="@drawable/widget_ai_bubble_user_bg"
            android:padding="8dp"
            android:text="Hỏi AI tử vi ›"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:maxLines="1" />

    </LinearLayout>

    <!-- ===== INPUT BAR ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="10dp"
        android:paddingTop="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:background="@drawable/widget_ai_input_bg"
            android:text="Hỏi gì đó..."
            android:textSize="11sp"
            android:textColor="#857371" />

        <FrameLayout
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/widget_ai_send_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="›"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

        </FrameLayout>

    </LinearLayout>

</LinearLayout>
