<?xml version="1.0" encoding="utf-8"?>
<!-- Widget 3×2 — AI Chat (DARK theme — deep red, matching other widgets) -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_ai_card_bg_dark">

    <!-- ===== HEADER ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:background="@drawable/widget_ai_header_bg_dark"
        android:padding="10dp">

        <!-- Avatar circle -->
        <FrameLayout
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:background="@drawable/widget_ai_avatar_bg">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="✦"
                android:textSize="14sp"
                android:textColor="#FFD54F" />

        </FrameLayout>

        <!-- Name + status -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:paddingStart="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Lịch Số AI"
                android:textSize="12sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

            <TextView
                android:id="@+id/tv_ai_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="● Đang hoạt động"
                android:textSize="9sp"
                android:textColor="#99FFFFFF" />

        </LinearLayout>

        <!-- Date badge -->
        <TextView
            android:id="@+id/tv_ai_date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="7/4"
            android:textSize="10sp"
            android:textColor="#CCFFFFFF" />

    </LinearLayout>

    <!-- ===== CHAT AREA ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:padding="8dp"
        android:gravity="top">

        <!-- AI bubble -->
        <TextView
            android:id="@+id/tv_ai_bubble"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/widget_ai_bubble_bg_dark"
            android:padding="6dp"
            android:text="✦ Hôm nay Ngày Hoàng Đạo, hướng tài lộc Đông Nam"
            android:textSize="9sp"
            android:textColor="#E0E0E0"
            android:maxLines="4"
            android:ellipsize="end" />

        <!-- User-like prompt bubble (aligned right) -->
        <TextView
            android:id="@+id/tv_ai_user_bubble"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:layout_marginTop="4dp"
            android:background="@drawable/widget_ai_bubble_user_bg_dark"
            android:padding="8dp"
            android:text="Hỏi AI tử vi ›"
            android:textSize="10sp"
            android:textColor="#FFFFFF"
            android:maxLines="1" />

    </LinearLayout>

    <!-- ===== INPUT BAR ===== -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="8dp"
        android:paddingEnd="8dp"
        android:paddingBottom="10dp"
        android:paddingTop="2dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="30dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:paddingStart="12dp"
            android:background="@drawable/widget_ai_input_bg_dark"
            android:text="Hỏi gì đó..."
            android:textSize="11sp"
            android:textColor="#99FFFFFF" />

        <FrameLayout
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="6dp"
            android:background="@drawable/widget_ai_send_bg_dark">

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="›"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="#FFFFFF" />

        </FrameLayout>

    </LinearLayout>

</LinearLayout>
