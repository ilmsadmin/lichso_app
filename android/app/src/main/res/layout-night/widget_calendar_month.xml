        <TextView android:id="@+id/cell_4_3" android:layout_width="0dp" android:layout_height="match_parent" android:layout_weight="1" android:gravity="center" android:fontFamily="sans-serif-medium" android:textSize="14sp" android:textColor="#E0E0E0" android:maxLines="2" android:includeFontPadding="false" android:lineSpacingMultiplier="0.85" />
