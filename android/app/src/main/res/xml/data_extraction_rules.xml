<?xml version="1.0" encoding="utf-8"?>
<!--
    Data extraction rules for Android 12+ (API 31+).
    Controls both cloud backup and device-to-device transfer.
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclude all sensitive local data from cloud backup -->
        <exclude domain="database" path="lichso.db" />
        <exclude domain="database" path="lichso.db-journal" />
        <exclude domain="database" path="lichso.db-shm" />
        <exclude domain="database" path="lichso.db-wal" />
        <exclude domain="file" path="datastore/ai_memory.preferences_pb" />
        <exclude domain="file" path="datastore/lichso_settings.preferences_pb" />
        <exclude domain="sharedpref" path="." />
    </cloud-backup>

    <device-transfer>
        <!-- Allow device-to-device transfer for convenience (less risky than cloud) -->
        <include domain="database" path="lichso.db" />
        <include domain="file" path="datastore/" />
    </device-transfer>
</data-extraction-rules>
