<?xml version="1.0" encoding="utf-8"?>
<!--
    Backup rules for Android Auto Backup (API < 31).
    Exclude sensitive data from cloud backups.
-->
<full-backup-content>
    <!-- Exclude database (contains personal data, family tree, chat history) -->
    <exclude domain="database" path="lichso.db" />
    <exclude domain="database" path="lichso.db-journal" />
    <exclude domain="database" path="lichso.db-shm" />
    <exclude domain="database" path="lichso.db-wal" />

    <!-- Exclude DataStore preferences (contains AI memory, personal info) -->
    <exclude domain="file" path="datastore/ai_memory.preferences_pb" />
    <exclude domain="file" path="datastore/lichso_settings.preferences_pb" />

    <!-- Exclude shared prefs -->
    <exclude domain="sharedpref" path="." />
</full-backup-content>
