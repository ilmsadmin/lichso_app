<vector xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:aapt="http://schemas.android.com/aapt"
    android:width="120dp"
    android:height="120dp"
    android:viewportWidth="100"
    android:viewportHeight="100">

    <!-- Left rounded-corner shape -->
    <path
        android:pathData="M38,12 C22,12 12,22 12,38 L12,52 C12,68 22,78 38,78 L52,78"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="12"
                android:startY="12"
                android:endX="52"
                android:endY="78">
                <item android:offset="0" android:color="#CCFFFFFF"/>
                <item android:offset="0.6" android:color="#99FFFFFF"/>
                <item android:offset="1" android:color="#80FFFFFF"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Right rounded-corner shape -->
    <path
        android:pathData="M48,22 L62,22 C78,22 88,32 88,48 L88,62 C88,78 78,88 62,88 L48,88"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:strokeLineJoin="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="48"
                android:startY="22"
                android:endX="88"
                android:endY="88">
                <item android:offset="0" android:color="#B3FFFFFF"/>
                <item android:offset="0.5" android:color="#99BBBBBB"/>
                <item android:offset="1" android:color="#80AAAAAA"/>
            </gradient>
        </aapt:attr>
    </path>

    <!-- Connecting diagonal stroke (the Z bridge) -->
    <path
        android:pathData="M52,78 L48,22"
        android:strokeWidth="10"
        android:strokeLineCap="round"
        android:fillColor="#00000000">
        <aapt:attr name="android:strokeColor">
            <gradient
                android:type="linear"
                android:startX="48"
                android:startY="22"
                android:endX="52"
                android:endY="78">
                <item android:offset="0" android:color="#B3FFFFFF"/>
                <item android:offset="1" android:color="#99FFFFFF"/>
            </gradient>
        </aapt:attr>
    </path>
</vector>
